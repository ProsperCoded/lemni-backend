# Server Configuration
PORT=3000

# Database Configuration (Turso / libSQL)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Nomba API Gateway Credentials
NOMBA_CLIENT_KEY=your-nomba-client-key
NOMBA_CLIENT_SECRET=your-nomba-client-secret
NOMBA_ACCOUNT_ID=your-nomba-account-id
NOMBA_API_URL=https://api.nomba.com

# Redis Configuration (BullMQ / Upstash)
REDIS_URL=rediss://default:your-password@your-redis-instance.upstash.io:6379

# Security Configuration
API_KEY_SALT_OR_ROUNDS=10
JWT_SECRET=your-jwt-dashboard-secret-key

# Notification Integrations (Optional / Fallback channels)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=your-whatsapp-token
